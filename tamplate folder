<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script>
    const today = new Date();
    const sevenDaysAgo = new Date(); sevenDaysAgo.setDate(today.getDate() - 7);
    const minDate = new Date('2026-05-01');
    document.getElementById('from_date').value = (sevenDaysAgo < minDate ? minDate : sevenDaysAgo).toISOString().split('T')[0];
    document.getElementById('to_date').value = today.toISOString().split('T')[0];
    
    let autoRefresh = setInterval(loadData, 10000);
    loadData();
    
    async function loadData() {
        const params = new URLSearchParams({
            from_date: document.getElementById('from_date').value,
            to_date: document.getElementById('to_date').value,
            device: document.getElementById('device').value,
            employee_name: document.getElementById('employee_name').value
        });
        const response = await fetch(`/get_attendance?${params}`);
        const data = await response.json();
        
        document.getElementById('total_count').innerText = data.summary.total;
        document.getElementById('present_count').innerText = data.summary.present;
        document.getElementById('late_count').innerText = data.summary.late;
        document.getElementById('absent_count').innerText = data.summary.absent;
        document.getElementById('footer_note').style.display = data.summary.absent > 0 ? 'block' : 'none';
        
        const tbody = document.getElementById('table_body');
        tbody.innerHTML = '';
        if (data.records.length === 0) {
            tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;">No records found</td></tr>';
        } else {
            for (const r of data.records) {
                const row = tbody.insertRow();
                let statusClass = r.status.includes('Absent') || r.status === 'Weekly Off' ? 'status-absent' : (r.status.includes('Late') ? 'status-late' : (r.status.includes('Missing') ? 'status-missing' : 'status-present'));
                
                if (r.original_day === 'Sunday') row.className = 'sunday-row';
                else if (r.original_day === 'Saturday') row.className = 'saturday-row';
                
                if (r.is_sunday) {
                    // Sunday row: merged Check In/Out
                    row.innerHTML = `
                        <td>${r.date}</td>
                        <td>${r.day}</td>
                        <td>${r.device}</td>
                        <td>${r.employee_name}</td>
                        <td colspan="2" style="text-align:center; font-weight:bold; color:#e65100;">${r.check_in}</td>
                        <td><span class="status-badge ${statusClass}">${r.status}</span></td>
                    `;
                } else {
                    // Normal days
                    row.innerHTML = `
                        <td>${r.date}</td>
                        <td>${r.day}</td>
                        <td>${r.device}</td>
                        <td>${r.employee_name}</td>
                        <td>${r.check_in}</td>
                        <td>${r.check_out}</td>
                        <td><span class="status-badge ${statusClass}">${r.status}</span></td>
                    `;
                }
            }
        }
    }
    
    function resetFilters() {
        const today = new Date();
        const seven = new Date(); seven.setDate(today.getDate() - 7);
        document.getElementById('from_date').value = (seven < new Date('2026-05-01') ? new Date('2026-05-01') : seven).toISOString().split('T')[0];
        document.getElementById('to_date').value = today.toISOString().split('T')[0];
        document.getElementById('device').value = 'all';
        document.getElementById('employee_name').value = '';
        loadData();
    }
    
    async function exportPDF() {
        const params = new URLSearchParams({
            from_date: document.getElementById('from_date').value,
            to_date: document.getElementById('to_date').value,
            device: document.getElementById('device').value,
            employee_name: document.getElementById('employee_name').value
        });
        const response = await fetch(`/get_attendance?${params}`);
        const data = await response.json();
        let rows = '';
        for (const r of data.records) {
            let bg = r.original_day === 'Sunday' ? '#fff3e0' : (r.original_day === 'Saturday' ? '#e3f2fd' : 'white');
            if (r.is_sunday) {
                rows += `<tr style="background:${bg}"><td>${r.date}</td><td>${r.day}</td><td>${r.device}</td><td>${r.employee_name}</td><td colspan="2" style="text-align:center;">${r.check_in}</td><td>${r.status}</td></tr>`;
            } else {
                rows += `<tr style="background:${bg}"><td>${r.date}</td><td>${r.day}</td><td>${r.device}</td><td>${r.employee_name}</td><td>${r.check_in}</td><td>${r.check_out}</td><td>${r.status}</td></tr>`;
            }
        }
        const html = `<div style="padding:20px"><h2 style="text-align:center">AL USMAN ENTERPRISE</h2><h3 style="text-align:center">Attendance Report</h3><p>${new Date().toLocaleString()}</p><table border="1" style="width:100%;border-collapse:collapse">${document.querySelector('#attendance_table thead').outerHTML}<tbody>${rows}</tbody></table><p style="margin-top:20px">Note: document your truancy</p></div>`;
        const element = document.createElement('div'); element.innerHTML = html;
        html2pdf().set({margin:0.5, filename:`attendance_${new Date().toISOString().split('T')[0]}.pdf`, jsPDF:{unit:'in', format:'a4', orientation:'landscape'}}).from(element).save();
    }
    
    function exportCSV() {
        let csv = [['Date','Day','Device','Employee Name','Check In','Check Out','Status']];
        document.querySelectorAll('#attendance_table tbody tr').forEach(row => {
            if (!row.innerText.includes('No records')) {
                csv.push(Array.from(row.cells).map(cell => `"${cell.innerText.trim()}"`));
            }
        });
        const blob = new Blob([csv.map(row => row.join(',')).join('\n')], {type:'text/csv'});
        const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = `attendance_${new Date().toISOString().split('T')[0]}.csv`; a.click();
    }
    
    function printReport() { window.print(); }
    function logout() { if(confirm('Logout?')) window.location.href = '/logout'; }
</script>
</body>
</html>

